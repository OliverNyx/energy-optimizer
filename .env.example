# ─────────────────────────────────────────────────────────────
# .env.example
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=false

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins, or * for development
CORS_ORIGINS=https://myproject.uab.es,http://localhost

# ── Paths (Docker-internal) ───────────────────────────────────
DATA_DIR=/app/data
MODELS_DIR=/app/models
LOG_DIR=/app/logs
STATIC_DIR=/app/static

# ── Logging ───────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Domain / model ────────────────────────────────────────────
# Number of houses sharing the solar installation
N_HOUSES=13

# Start date for generating the PVPC hourly timestamp index
PRICE_START_DATE=2023-01-01 00:00:00

# ── Gunicorn ──────────────────────────────────────────────────
# Keep at 1 unless you move STATE to Redis (see README §Scaling)
GUNICORN_WORKERS=1
GUNICORN_BIND=0.0.0.0:5000
GUNICORN_TIMEOUT=120
